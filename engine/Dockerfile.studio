FROM python:3.12-slim

# Install uv
RUN pip install --no-cache-dir uv

WORKDIR /app

# Copy dependency manifests first so uv sync is pinned/reproducible
COPY pyproject.toml uv.lock ./

# Install with the serve extra (fastapi + uvicorn + sse-starlette)
RUN uv sync --extra serve

# Copy package source after deps are installed (better layer caching)
COPY offside_engine/ offside_engine/

EXPOSE 8000
