# ── Local-only planning (never committed) ──────────────────────────────
_local/
*.local.md

# ── Local tooling state (not part of the project) ─────────────────────
.claude/
.veris/

# ── Secrets / env ──────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ── Data licensing: raw StatsBomb must never be committed ──────────────
corpus/statsbomb/**/*.json
**/*.statsbomb.json
**/events/

# ── Python engine ──────────────────────────────────────────────────────
engine/.venv/
engine/.hf_cache/
engine/spikes/
engine/build/

# ── Bulky Docling intermediates (rebuildable; only curated/frozen data is kept) ──
data/docling/*.p*-*.json
data/docling/*.citations.json

# ── LanceDB index: a binary build artifact the bake regenerates deterministically ──
data/lance/
**/__pycache__/
*.py[cod]
.pytest_cache/
.ruff_cache/
.mypy_cache/

# ── Node / Next.js (web) ───────────────────────────────────────────────
node_modules/
web/.next/
web/out/
.vercel/
*.tsbuildinfo

# ── Caches / OS ────────────────────────────────────────────────────────
.cache/
**/.cache/
.DS_Store
Thumbs.db
*.log
