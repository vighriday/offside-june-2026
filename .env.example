# OFFSIDE environment template — copy to `.env` and fill in as needed.
# Nothing here is required to RUN the deployed app (it reads frozen fixtures).
# These are only used by the offline build (the "bake").

# ── Build host: where Granite + Docling run (Ollama, local to the bake host) ──
# Default points at a local Ollama server on the bake machine.
OLLAMA_HOST=http://127.0.0.1:11434
GRANITE_MODEL=granite3.3:8b
GRANITE_EMBED_MODEL=granite-embedding:30m

# Deterministic bake settings
GRANITE_TEMPERATURE=0
GRANITE_SEED=42
GRANITE_NUM_CTX=8192

# ── Optional: IBM watsonx.ai cross-check pass (offline blessing of fixtures) ──
# Used once, offline, to cross-check the 3 frozen fixtures. NEVER used at runtime.
# Leave blank to skip the watsonx pass entirely.
WATSONX_API_KEY=
WATSONX_PROJECT_ID=
WATSONX_URL=

# ── Optional: StatsBomb registration email (compliance courtesy) ──
STATSBOMB_REGISTERED_EMAIL=
